# ── Piano (Reader auth) ──────────────────────────────────────────
NEXT_PUBLIC_PIANO_AID=your_piano_application_id

# ── Sentry (Error monitoring) ────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/xxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=games-hub
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ── PostHog (Analytics) ──────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Sanity (CMS) ─────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token

# ── Cloudflare (Rate limiting + KV) ──────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cf_account_id
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id
CLOUDFLARE_API_TOKEN=your_cf_api_token

# ── Masthead config ───────────────────────────────────────────────
NEXT_PUBLIC_MASTHEAD=canberratimes
NEXT_PUBLIC_SITE_URL=https://games.canberratimes.com.au
NEXT_PUBLIC_COOKIE_DOMAIN=.canberratimes.com.au

# ── Firebase Cloud Messaging (Push notifications) ─────────────────
NEXT_PUBLIC_FCM_VAPID_KEY=your_fcm_vapid_key
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
